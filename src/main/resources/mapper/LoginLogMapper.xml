<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.molly.mapper.LoginLogMapper">

    <resultMap id="LoginLogResult" type="com.demo.molly.entity.LoginLog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="ip" column="ip"/>
        <result property="operation" column="operation"/>
        <result property="status" column="status"/>
        <result property="message" column="message"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_login_log (user_id, username, ip, operation, status, message)
        VALUES (#{userId}, #{username}, #{ip}, #{operation}, #{status}, #{message})
    </insert>

    <select id="selectList" resultMap="LoginLogResult">
        SELECT id, user_id, username, ip, operation, status, message, created_at
        FROM sys_login_log
        <where>
            <if test="startTime != null">
                AND created_at &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND created_at &lt;= #{endTime}
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM sys_login_log
        <where>
            <if test="startTime != null">
                AND created_at &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND created_at &lt;= #{endTime}
            </if>
        </where>
    </select>
</mapper>
